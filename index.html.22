<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GKS Quantum Runner</title>
    <style>
        body { margin: 0; background: #080710; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; color: #fff; }
        #gameContainer { position: relative; box-shadow: 0 0 40px rgba(0, 242, 254, 0.3); border-radius: 12px; overflow: hidden; }
        canvas { background: #0f0e17; display: block; }
        #ui { position: absolute; top: 20px; left: 20px; font-size: 22px; font-weight: bold; letter-spacing: 2px; text-shadow: 0 0 10px #00f2fe; }
        #instructions { position: absolute; bottom: 20px; width: 100%; text-align: center; font-size: 16px; color: #a0aab5; pointer-events: none; }
        #gameOverScreen { position: absolute; top: 0; left: 0; width: 800px; height: 500px; background: rgba(15, 14, 23, 0.85); display: flex; flex-direction: column; justify-content: center; align-items: center; backdrop-filter: blur(8px); display: none; }
        h1 { font-size: 48px; margin: 0 0 10px 0; color: #ff007f; text-shadow: 0 0 20px #ff007f; }
        button { background: linear-gradient(45deg, #00f2fe, #4facfe); border: none; padding: 12px 30px; font-size: 18px; color: white; border-radius: 25px; cursor: pointer; font-weight: bold; box-shadow: 0 4px 15px rgba(0,242,254,0.4); transition: 0.3s; }
        button:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(0,242,254,0.6); }
    </style>
</head>
<body>

<div id="gameContainer">
    <div id="ui">SCORE: <span id="scoreVal">0</span></div>
    <div id="instructions">اضغط على زر المسافة (SPACEBAR) أو انقر لتغيير الجاذبية فوراً!</div>
    <canvas id="gameCanvas" width="800" height="500"></canvas>
    
    <div id="gameOverScreen">
        <h1 id="overText">GAME OVER</h1>
        <p style="font-size: 20px; margin-bottom: 20px;">النقاط التي حققتها: <span id="finalScore">0</span></p>
        <button onclick="resetGame()">تحدي اللجنة مجدداً</button>
    </div>
</div>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

let score = 0;
let gameActive = true;

// اللاعب
let player = {
    x: 100,
    y: 250,
    size: 24,
    vy: 0,
    gravity: 0.6,
    color: "#00f2fe"
};

// العوائق والجسيمات جمالية
let obstacles = [];
let particles = [];
let obstacleSpeed = 5;
let spawnTimer = 0;

// الاستماع للمفاتيح والنقرات
window.addEventListener("keydown", (e) => { if(e.code === "Space") reverseGravity(); });
canvas.addEventListener("mousedown", reverseGravity);

function reverseGravity() {
    if(!gameActive) return;
    player.gravity = -player.gravity;
    // إضافة جسيمات جمالية عند القفز
    for(let i=0; i<8; i++) {
        particles.push({
            x: player.x, y: player.y,
            vx: (Math.random() - 0.5) * 4, vy: (Math.random() - 0.5) * 4,
            size: Math.random() * 4 + 2, color: "#ff007f", alpha: 1
        });
    }
}

function spawnObstacle() {
    let type = Math.random() > 0.5 ? "top" : "bottom";
    let height = Math.random() * 150 + 80;
    obstacles.push({
        x: canvas.width,
        y: type === "top" ? 0 : canvas.height - height,
        width: 35,
        height: height,
        color: type === "top" ? "#ff007f" : "#7f00ff"
    });
}

function update() {
    if(!gameActive) return;

    // حركة اللاعب وتحديث الجاذبية
    player.vy += player.gravity;
    player.y += player.vy;

    // حدود الشاشة
    if(player.y - player.size/2 < 0) { player.y = player.size/2; player.vy = 0; }
    if(player.y + player.size/2 > canvas.height) { player.y = canvas.height - player.size/2; player.vy = 0; }

    // إنشاء عوائق بطريقة دورية ذكية
    spawnTimer++;
    if(spawnTimer > 70) {
        spawnObstacle();
        spawnTimer = 0;
        if(obstacleSpeed < 10) obstacleSpeed += 0.2; // زيادة الصعوبة تدريجياً لتبهرهم
    }

    // تحديث العوائق
    for(let i = obstacles.length - 1; i >= 0; i--) {
        obstacles[i].x -= obstacleSpeed;

        // التحقق من التصادم البدني (Collision)
        if (player.x + player.size/2 > obstacles[i].x && 
            player.x - player.size/2 < obstacles[i].x + obstacles[i].width &&
            player.y + player.size/2 > obstacles[i].y && 
            player.y - player.size/2 < obstacles[i].y + obstacles[i].height) {
                endGame();
        }

        // زيادة النقاط عند تجاوز العائق
        if(obstacles[i].x + obstacles[i].width < player.x && !obstacles[i].passed) {
            obstacles[i].passed = true;
            score += 10;
            document.getElementById("scoreVal").innerText = score;
        }

        if(obstacles[i].x + obstacles[i].width < 0) obstacles.splice(i, 1);
    }

    // تحديث المؤثرات البصرية للجسيمات
    if(Math.random() > 0.4) {
        particles.push({
            x: player.x - 10, y: player.y,
            vx: -Math.random()*2 - 1, vy: (Math.random() - 0.5)*2,
            size: Math.random()*5, color: player.color, alpha: 1
        });
    }

    for(let i = particles.length - 1; i >= 0; i--) {
        particles[i].x += particles[i].vx;
        particles[i].y += particles[i].vy;
        particles[i].alpha -= 0.02;
        if(particles[i].alpha <= 0) particles.splice(i, 1);
    }
}

function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // رسم تأثير النيون الخلفي للشبكة الإلكترونية
    ctx.strokeStyle = "rgba(255, 255, 255, 0.03)";
    ctx.lineWidth = 1;
    for(let i=0; i<canvas.width; i+=40) { ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i,canvas.height); ctx.stroke(); }
    for(let j=0; j<canvas.height; j+=40) { ctx.beginPath(); ctx.moveTo(0,j); ctx.lineTo(canvas.width,j); ctx.stroke(); }

    // رسم المؤثرات البصرية المتطايرة الخلفية
    particles.forEach(p => {
        ctx.save();
        ctx.globalAlpha = p.alpha;
        ctx.shadowBlur = 10;
        ctx.shadowColor = p.color;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
        ctx.fill();
        ctx.restore();
    });

    // رسم اللاعب بتأثير إضاءة نيون توحي بالاحترافية
    ctx.save();
    ctx.shadowBlur = 20;
    ctx.shadowColor = player.color;
    ctx.fillStyle = player.color;
    ctx.beginPath();
    ctx.arc(player.x, player.y, player.size/2, 0, Math.PI*2);
    ctx.fill();
    ctx.restore();

    // رسم العوائق المستطيلة المتوهجة
    obstacles.forEach(obs => {
        ctx.save();
        ctx.shadowBlur = 15;
        ctx.shadowColor = obs.color;
        ctx.fillStyle = obs.color;
        ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
        ctx.restore();
    });
}

function loop() {
    update();
    draw();
    requestAnimationFrame(loop);
}

function endGame() {
    gameActive = false;
    document.getElementById("finalScore").innerText = score;
    document.getElementById("gameOverScreen").style.display = "flex";
}

function resetGame() {
    score = 0;
    document.getElementById("scoreVal").innerText = "0";
    obstacles = [];
    particles = [];
    obstacleSpeed = 5;
    player.y = 250;
    player.vy = 0;
    player.gravity = 0.6;
    gameActive = true;
    document.getElementById("gameOverScreen").style.display = "none";
}

// تشغيل المحرك فورا
loop();
</script>

</body>
</html>
